{
  "name": "ifcalendar-js",
  "version": "1.0.4",
  "description": "A lightweight JavaScript library for converting dates between the normal Gregorian calendar and the International Fixed Calendar (IFC).",
  "type": "module",
  "bin": {
    "ifcalendar": "./bin/ifcalendar.js"
  },
  "scripts": {
    "build": "tsup src/index.js --format cjs,esm --clean --dts --minify --sourcemap --no-sourcemap",
    "postbuild": "cp dist/index.js docs/index.js",
    "prepublishOnly": "npm run build"
    "dry-run": "npm publish --dry-run",
    "test": "jest"
  },
  "files": [
    "dist/index.js",
    "dist/index.cjs",
    "bin",
    "locales",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "jest": {
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1.js"
    },
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js",
      "**/*.spec.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gooddadmike/ifcalendar-js.git"
  },
  "homepage": "https://github.com/gooddadmike/ifcalendar-js#readme",
  "keywords": [
    "calendar",
    "ifc",
    "international-fixed-calendar",
    "date",
    "cotsworth",
    "eastman",
    "yearal",
    "kodak",
    "13-month-calendar"
  ],
  "author": "Mike Searcy",
  "license": "MIT",
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
